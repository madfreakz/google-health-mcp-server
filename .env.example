# Google Health API OAuth credentials.
# Create them in Google Cloud Console:
#   1. Create / pick a project, then enable the Google Health API:
#      https://console.cloud.google.com/apis/library/health.googleapis.com
#   2. Configure the OAuth consent screen (External, your own email as a Test user).
#   3. Add the googlehealth.*.readonly scopes on the Data Access page.
#   4. Create an OAuth client of type "Web application" and add this redirect URI:
#         http://localhost:47813/callback
#      (must match GOOGLE_HEALTH_OAUTH_PORT below)
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=

# Where rotating access + refresh tokens are persisted (written mode 0600).
# Default if unset: ~/.config/google-health-mcp/tokens.json
GOOGLE_HEALTH_TOKENS_PATH=

# Local port the OAuth bootstrap listens on for the redirect callback.
# Must match the redirect URI registered on your OAuth client. Default: 47813
GOOGLE_HEALTH_OAUTH_PORT=

# Root of your Obsidian vault. Sync writes daily notes under {vault}/Lifestyle/Health/
# and a dashboard at {vault}/Lifestyle/Health-Dashboard.md.
# Leave unset to disable Obsidian sync (all other tools still work).
OBSIDIAN_VAULT_PATH=
